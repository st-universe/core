<style>
    .regionMapControls {
        display: flex;
        gap: 14px;
        margin-bottom: 6px;
        align-items: center;
    }

    .regionMapControls label {
        display: inline-flex;
        gap: 5px;
        align-items: center;
        white-space: nowrap;
    }

    #regionmaptable .regionMapCellInner {
        cursor: auto !important;
        touch-action: manipulation;
    }

    #regionmaptable.regionMapShowEffects td[data-region-effects="1"] .regionMapCellInner::before,
    #regionmaptable.regionMapShowImpassable td[data-region-impassable="1"] .regionMapCellInner::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
    }

    #regionmaptable.regionMapShowEffects td[data-region-effects="1"] .regionMapCellInner::before {
        box-shadow: inset 0 0 0 2px var(--color-35);
        z-index: 3;
    }

    #regionmaptable.regionMapShowImpassable td[data-region-impassable="1"] .regionMapCellInner::after {
        background:
            linear-gradient(135deg, transparent 0 42%, var(--color-25) 42% 52%, transparent 52%),
            linear-gradient(45deg, transparent 0 42%, var(--color-25) 42% 52%, transparent 52%);
        z-index: 4;
    }

    .regionMapTooltip {
        position: fixed;
        display: none;
        max-width: 360px;
        padding: 6px 8px;
        border: 1px solid var(--color-53);
        background: var(--color-31);
        color: var(--color-56);
        line-height: 1.35;
        white-space: pre-line;
        pointer-events: none;
        z-index: 10000;
        box-shadow: 0 0 0 1px var(--color-53), 0 4px 12px #000000;
    }
</style>

<table class="tcal">
    <tr>
        <th colspan="2">Regionsdetails</th>
    </tr>
    <tr>
        <td class="darkbg">Name</td>
        <td>{{ REGION.getDescription }}</td>
    </tr>
    {% if MAP_DATA %}
    <tr>
        <td colspan="2">
            <div class="divhead">Regionskarte</div>
            <div class="divbody">
                <div class="regionMapControls">
                    <label><input type="checkbox" id="regionMapShowImpassable" /> Unpassierbar
                        markieren</label>
                    <label><input type="checkbox" id="regionMapShowEffects" /> Effekte
                        markieren</label>
                </div>
                <div id="regionMapTooltip" class="regionMapTooltip"></div>
                <table id="regionmaptable" class="use">
                    <tr>
                        <th>x|y</th>
                        {% for head in MAP_DATA.head_row %}
                        <th>{{ head }}</th>
                        {% endfor %}
                    </tr>
                    {% for yrow in MAP_DATA.fields %}
                    <tr>
                        <th>{{ yrow.row }}</th>
                        {% for data in yrow.fields %}
                        <td class="starmap" style="{{ data.style }}" id="{{ data.cx }}_{{ data.cy }}"
                            data-region-tooltip="{{ data.tooltip|e('html_attr') }}"
                            data-region-effects="{{ data.has_effects ? '1' : '0' }}"
                            data-region-impassable="{{ data.is_impassable ? '1' : '0' }}">
                            <div class="starmapInner regionMapCellInner">
                                {% if data.icon_path %}
                                <img src="/assets/map/{{ data.icon_path }}" style="height: 28px; width: 28px;"
                                    alt="Regionskarte" />
                                {% else %}
                                &nbsp;
                                {% endif %}
                            </div>
                        </td>
                        {% endfor %}
                    </tr>
                    {% endfor %}
                </table>
            </div>
        </td>
    </tr>
    {% endif %}
</table>

{% if MAP_DATA %}
<script>
    (function () {
        var table = document.getElementById('regionmaptable');
        var tooltip = document.getElementById('regionMapTooltip');
        var showImpassable = document.getElementById('regionMapShowImpassable');
        var showEffects = document.getElementById('regionMapShowEffects');
        var isTouchTooltipMode = window.matchMedia
            ? window.matchMedia('(hover: none), (pointer: coarse)').matches
            : false;
        var pinnedCell = null;

        if (!table || !tooltip || !showImpassable || !showEffects) {
            return;
        }

        function syncFilters() {
            table.classList.toggle('regionMapShowImpassable', showImpassable.checked);
            table.classList.toggle('regionMapShowEffects', showEffects.checked);
        }

        function getTooltipCell(target) {
            if (!target) {
                return null;
            }
            if (target.nodeType !== 1) {
                target = target.parentElement;
            }
            if (!target || typeof target.closest !== 'function') {
                return null;
            }

            var cell = target.closest('[data-region-tooltip]');
            return cell && table.contains(cell) ? cell : null;
        }

        function showTooltip(cell) {
            var text = cell ? cell.getAttribute('data-region-tooltip') : '';

            if (!text) {
                hideTooltip();
                return false;
            }

            tooltip.textContent = text;
            tooltip.style.display = 'block';
            return true;
        }

        function positionTooltipByMouse(event) {
            var margin = 12;
            var left = event.clientX + margin;
            var top = event.clientY + margin;

            tooltip.style.left = left + 'px';
            tooltip.style.top = top + 'px';

            var rect = tooltip.getBoundingClientRect();
            var maxLeft = window.innerWidth - rect.width - margin;
            var maxTop = window.innerHeight - rect.height - margin;

            if (left > maxLeft) {
                left = event.clientX - rect.width - margin;
            }
            if (top > maxTop) {
                top = event.clientY - rect.height - margin;
            }

            tooltip.style.left = Math.max(margin, left) + 'px';
            tooltip.style.top = Math.max(margin, top) + 'px';
        }

        function positionTooltipByCell(cell) {
            var margin = 12;
            var cellRect = cell.getBoundingClientRect();
            var tooltipRect = tooltip.getBoundingClientRect();
            var left = cellRect.right + margin;
            var top = cellRect.top;

            if (left + tooltipRect.width + margin > window.innerWidth) {
                left = cellRect.left - tooltipRect.width - margin;
            }
            if (left < margin) {
                left = margin;
                top = cellRect.bottom + margin;
            }
            if (top + tooltipRect.height + margin > window.innerHeight) {
                top = cellRect.top - tooltipRect.height - margin;
            }

            tooltip.style.left = Math.max(margin, Math.min(left, window.innerWidth - tooltipRect.width - margin)) + 'px';
            tooltip.style.top = Math.max(margin, Math.min(top, window.innerHeight - tooltipRect.height - margin)) + 'px';
        }

        function hideTooltip() {
            tooltip.style.display = 'none';
            pinnedCell = null;
        }

        showImpassable.addEventListener('change', syncFilters);
        showEffects.addEventListener('change', syncFilters);
        syncFilters();

        if (isTouchTooltipMode) {
            table.addEventListener('click', function (event) {
                var cell = getTooltipCell(event.target);

                if (!cell) {
                    return;
                }

                event.preventDefault();
                event.stopPropagation();

                if (pinnedCell === cell && tooltip.style.display === 'block') {
                    hideTooltip();
                    return;
                }

                pinnedCell = cell;
                if (showTooltip(cell)) {
                    positionTooltipByCell(cell);
                }
            });

            document.addEventListener('click', function () {
                hideTooltip();
            });

            window.addEventListener('resize', hideTooltip);
            window.addEventListener('scroll', hideTooltip, true);
        } else {
            table.addEventListener('mousemove', function (event) {
                var cell = getTooltipCell(event.target);

                if (!cell || !showTooltip(cell)) {
                    return;
                }

                positionTooltipByMouse(event);
            });

            table.addEventListener('mouseleave', hideTooltip);
        }
    })();
</script>
{% endif %}
