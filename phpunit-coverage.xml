<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         backupGlobals="false"
         bootstrap="tests/Bootstrap.php"
         colors="true"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.2/phpunit.xsd"
         cacheDirectory="build/.phpunit.cache"
         processIsolation="false"
         stopOnFailure="false">
    <testsuites>
        <testsuite name="STU">
            <directory suffix="Test.php">./tests</directory>
        </testsuite>
    </testsuites>
    <php>
        <server name="APP_ENV" value="testing"/>
    </php>
    <filter>
        <whitelist processUncoveredFilesFromWhitelist="true">
            <directory suffix=".php">src/Component</directory>
            <directory suffix=".php">src/Lib</directory>
            <directory suffix=".php">src/Module</directory>
            <directory suffix=".php">src/Orm</directory>
            <exclude>
              <directory suffix="services.php">src</directory>
              <directory>src/Migrations</directory>
              <directory>src/OrmProxy</directory>
            </exclude>
        </whitelist>
    </filter>
</phpunit>
